# ============================================================
# Local environment template — copy to .env.local and fill in
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-min-32-chars

# ── Kong API Gateway ─────────────────────────────────────────
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://localhost:8080

# ── Auth (Keycloak — local only) ────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ocr-platform
KEYCLOAK_CLIENT_ID=ocr-api
KEYCLOAK_CLIENT_SECRET=change-me

# ── Database ─────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:password@mongodb:27017/ocrplatform?authSource=admin
MONGODB_DB=ocrplatform

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@redis:6379/0

# ── Object Storage (MinIO locally, S3 in prod) ──────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=ocr-uploads
MINIO_BUCKET_RESULTS=ocr-results
MINIO_USE_SSL=false
PRESIGNED_URL_EXPIRY_SECONDS=900

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_OCR_PENDING=ocr.jobs.pending
KAFKA_TOPIC_OCR_COMPLETED=ocr.jobs.completed
KAFKA_TOPIC_OCR_FAILED=ocr.jobs.failed
KAFKA_TOPIC_QUOTA_ALERTS=quota.alerts
KAFKA_CONSUMER_GROUP=ocr-workers

# ── Triton Inference Server ──────────────────────────────────
TRITON_GRPC_URL=triton:8001
TRITON_HTTP_URL=http://triton:8000
TRITON_MODEL_DETECTION=ocr_detection
TRITON_MODEL_RECOGNITION=ocr_recognition
TRITON_MODEL_ENSEMBLE=ocr_ensemble

# ── LLM — OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# ── LLM — Ollama (local fallback) ────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# ── LLM Model Router ─────────────────────────────────────────
# Options: openai | ollama | auto
LLM_ROUTING_STRATEGY=auto
# Paid users always get OpenAI; free users get Ollama
LLM_FREE_TIER_MODEL=ollama
LLM_PAID_TIER_MODEL=openai

# ── Langfuse (LLM Observability) ─────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local-change-me
LANGFUSE_SECRET_KEY=sk-lf-local-change-me

# ── ClamAV ───────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── Payment ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me
RAZORPAY_KEY_ID=rzp_test_change-me
RAZORPAY_KEY_SECRET=change-me

# ── Service Ports (gRPC) ─────────────────────────────────────
AUTH_SERVICE_GRPC_PORT=50051
INGESTION_SERVICE_GRPC_PORT=50052
QUOTA_SERVICE_GRPC_PORT=50053
RESULT_SERVICE_GRPC_PORT=50054
NOTIFICATION_SERVICE_PORT=8005
CHAT_SERVICE_GRPC_PORT=50055

# ── Tier Config Cache TTL ─────────────────────────────────────
TIER_CONFIG_CACHE_TTL_SECONDS=60
